# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.mp3 binary
*.ogg binary
*.wav binary
*.tmx binary
*.tsx binary
